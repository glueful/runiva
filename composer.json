{
    "name": "glueful/runiva",
    "description": "Runiva: Server runtime integration for Glueful (RoadRunner, Swoole, FrankenPHP)",
    "type": "glueful-extension",
    "license": "MIT",
    "keywords": [
        "runtime",
        "server",
        "roadrunner",
        "swoole",
        "frankenphp"
    ],
    "require": {
        "php": "^8.3",
        "nyholm/psr7": "^1.6",
        "symfony/psr-http-message-bridge": ">=2.0 <8.0"
    },
    "require-dev": {
        "glueful/framework": "^1.50.1",
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.6",
        "spiral/roadrunner": "^2025.1",
        "spiral/roadrunner-http": "^4.0"
    },
    "homepage": "https://github.com/glueful/runiva",
    "autoload": {
        "psr-4": {
            "Glueful\\Extensions\\Runiva\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Glueful\\Extensions\\Runiva\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpcs": "vendor/bin/phpcs --standard=PSR12 src",
        "phpcbf": "vendor/bin/phpcbf --standard=PSR12 src",
        "analyze": "vendor/bin/phpstan analyse src --level=5"
    },
    "extra": {
        "glueful": {
            "name": "Runiva",
            "displayName": "Glueful Runiva",
            "description": "Server runtime integration for Glueful",
            "version": "0.9.0",
            "icon": "assets/icon.png",
            "categories": [
                "runtime",
                "server"
            ],
            "publisher": "glueful-team",
            "provider": "Glueful\\Extensions\\Runiva\\RunivaServiceProvider",
            "requires": {
                "glueful": ">=1.50.1",
                "extensions": []
            }
        }
    },
    "suggest": {
        "spiral/roadrunner": "Required to run the RoadRunner binary and base worker",
        "spiral/roadrunner-http": "Required to receive HTTP requests from RoadRunner in PSR-7 mode"
    },
    "config": {
        "sort-packages": true
    }
}
